{
	"name": "tigerflows",
	"private": true,
	"version": "2.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 1920 --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"db:gen": "bunx tsx --tsconfig ./tsconfig.json ./node_modules/drizzle-kit/bin.cjs generate",
		"db:mig": "bunx tsx --tsconfig ./tsconfig.json ./db/scripts/migrate.ts",
		"db:reset": "bunx tsx --tsconfig ./tsconfig.json ./db/scripts/migrate.ts --fresh",
		"db:build-system": "TURSO_DB_URL=file:./data/systemFlows.db bunx tsx --tsconfig ./tsconfig.json ./db/scripts/migrate.ts --fresh && TURSO_DB_URL=file:./data/systemFlows.db bunx tsx --tsconfig ./tsconfig.json ./db/scripts/seed.ts --system",
		"db:serve": "pglite-server --db=./data/pglite --port=5433 --extensions=@electric-sql/pglite-pgvector:vector --max-connections=10",
		"db:seed": "bun run db:build-system"
	},
	"devDependencies": {
		"@electric-sql/pglite-socket": "^0.2.1",
		"@iconify-json/lucide": "^1.2.111",
		"@iconify/tailwind": "^1.2.0",
		"@iconify/tailwind4": "^1.2.3",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.2",
		"drizzle-kit": "^0.31.10",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.2",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@bytemd/plugin-gfm": "^1.22.0",
		"@bytemd/plugin-highlight": "^1.22.0",
		"@electric-sql/pglite": "^0.5.1",
		"@electric-sql/pglite-pgvector": "^0.0.2",
		"@huggingface/transformers": "^4.2.0",
		"@libsql/client": "^0.17.3",
		"bytemd": "^1.22.0",
		"daisyui": "^5.5.20",
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"github-markdown-css": "^5.9.0",
		"highlight.js": "^11.11.1",
		"marked": "^18.0.5",
		"nanoid": "^5.1.11",
		"nanoid-dictionary": "^5.0.0",
		"zod": "^4.4.3"
	}
}
