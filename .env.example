# No database configuration needed for local-only development.
# By default TigerFlows uses a local libSQL file at ./data/userFlows.db.
#
# Optional: point the app/CLI at a remote Turso database.
# TURSO_DB_URL="libsql://..."
# TURSO_AUTH_TOKEN="..."

